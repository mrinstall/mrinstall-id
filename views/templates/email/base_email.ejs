<%
  var header = '_header';
  var footer = '_footer';

  var content;
  if (view) {
    content = include(view, data);
  } else {
    content = data;
  }

  if (config.site.theme !== 'default') {
    if(fs.existsSync('themes/' + config.site.theme + '/templates/email/_header.ejs')) {
      header = '../../../themes/' + config.site.theme + '/templates/email/_header';
    }

    if(fs.existsSync('themes/' + config.site.theme + '/templates/email/_footer.ejs')) {
      footer = '../../../themes/' + config.site.theme + '/templates/email/_footer';
    }

    if(view && fs.existsSync('themes/' + config.site.theme + '/templates/email/' + view + '.ejs')) {
      path = '../../../themes/' + config.site.theme + '/templates/email/' + view;
      content = include(path, data);
    }
  }
%>

<!DOCTYPE html>
<html>

<head>
  <meta content="text/html; charset=UTF-8" http-equiv="Content-Type">
</head>

<body>
  <table
    style="background-color: #050505; min-height: 300px; padding-bottom: 40px; border:0; font-family: verdana, arial, sans-serif;"
    cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td align="center" valign="top">
        <table style="padding: 15px 0px; border:0;" cellpadding="0" cellspacing="0" width="700">
          <tr style="background-color: #050505; min-height: 80px; display: block;">
            <td style="background-color: #111111; width:700px; border-radius: 12px 12px 0 0;">
              <%- include(header) %>
            </td>
          </tr>
          <tr style="height: auto; padding: 20px 15px 10px; color: #a1a1aa; background-color: #111111; font-size: 13px;">
            <td>
              <table
                style="height: auto; padding: 20px 15px 10px; color: #a1a1aa; background-color: #111111; font-size: 13px;">
                <tr>
                  <td>
                    <%- content %>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="border-top:1px solid rgba(255,255,255,0.1);"></td>
          </tr>
          <tr>
            <td
              style="border-top: 1px solid rgba(245, 158, 11, 0.5); border-bottom: 1px solid rgba(255,255,255,0.05); height: 0px; width: 100%; display:block;">
            </td>
          </tr>
          <tr style="background-color: #111111; border-radius: 0 0 12px 12px;">
            <td style="padding:15px 15px 0px; display: block; padding-bottom: 30px; font-size: 11px;">
              <%- include(footer) %>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>

</html>